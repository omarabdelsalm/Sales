@page "/login"
@using Sales.Shared.Services
@inject AuthService Auth
@inject NavigationManager Nav

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-logo">🛒</div>
        <h2>تسجيل الدخول</h2>
        <p class="auth-subtitle">أهلاً بك في متجرنا الإلكتروني</p>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-error">@_errorMessage</div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>البريد الإلكتروني</label>
                <input type="email" @bind="_model.Email" placeholder="example@mail.com" class="form-control" />
            </div>

            <div class="form-group">
                <label>كلمة المرور</label>
                <input type="password" @bind="_model.Password" placeholder="••••••••" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary" disabled="@_loading">
                @if (_loading) { <span>جارٍ الدخول...</span> } else { <span>دخول</span> }
            </button>
        </EditForm>

        <div class="auth-footer">
            ليس لديك حساب؟
            <a href="/register/customer">تسجيل كعميل</a> |
            <a href="/register/merchant">تسجيل كتاجر</a>
            <div style="margin-top: 15px; border-top: 1px solid #eee; pt-3">
                <a href="/" class="btn-link">تصفح كزائر</a>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginModel _model = new();
    private string _errorMessage = "";
    private bool _loading = false;

    private async Task HandleLogin()
    {
        _loading = true;
        _errorMessage = "";
        var (success, msg) = await Auth.LoginAsync(_model.Email, _model.Password);
        _loading = false;
        if (success)
            Nav.NavigateTo(Auth.IsMerchant ? "/merchant/dashboard" : "/");
        else
            _errorMessage = msg;
    }

    private class LoginModel
    {
        public string Email    { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
